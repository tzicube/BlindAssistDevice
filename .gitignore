# BlindAssistDevice repo-specific ignore rules

# Python / Django / AI server
__pycache__/
*.py[cod]
*.log
*.sqlite3
.pytest_cache/
.mypy_cache/
.ruff_cache/

venv/
env/
.venv/

# Local environment and secrets
.env
.env.*
!.env.example
secret_key.txt

# Frontend tooling
node_modules/
dist/
.cache/

# ESP32 / PlatformIO build output
.pio/
.pioenvs/
.pio/build/
*.o
*.a
*.elf
*.bin
*.map

# AI model and runtime artifacts
runs/
*.pt
*.onnx
*.h5
*.tflite

# Generated media and temporary files
*.wav
*.mp3
*.pcm
*.aac
*.mp4
*.avi
logs/
tmp/
*.tmp
*.bak

!AiServer/ai_server/core/speech/*.wav
AiServer/.model_cache/
AiServer/temp_audio/

# Editor / OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db
